{
  "name": "to-do-list-cli",
  "private": true,
  "version": "0.1.0",
  "description": "A CLI to manage your tasks efficiently",
  "type": "module",
  "bin": {
    "todo": "./bin/todo.js"
  },
  "scripts": {
    "todo": "node bin/todo.js",
    "dev:server": "node --watch server/index.js",
    "dev:web": "npm run dev --prefix web",
    "dev": "concurrently -n server,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "start:server": "node server/index.js",
    "lint": "oxlint",
    "test": "node --test"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "cors": "^2.8.5",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "oxlint": "^1.69.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
